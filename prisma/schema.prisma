// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  STUDENT
}

enum AccountStatus {
  ACTIVE
  LOCKED
}

enum Level {
  CUSTOMER
  NEW_STARTER
  JUNIOR
  SENIOR
  CORE_LEADER
}

enum LevelUpStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AnnouncementCategory {
  IMPORTANT
  UPDATE
  GENERAL
}

enum LibraryItemType {
  BOOK
  DOCUMENT
}

// Discriminates how a LibraryItem is authored/served — PDF (uploaded file,
// today's only path) vs INTERACTIVE (pages composed in the admin editor,
// see LibraryBookPage). Independent of LibraryItemType (BOOK/DOCUMENT),
// which is about the item's physical form, not its content source.
enum LibraryItemFormat {
  PDF
  INTERACTIVE
}

enum ChatThreadKind {
  SUPPORT
  DIRECT
  GROUP
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

enum OrderItemKind {
  COURSE
  LIBRARY_ITEM
  PRODUCT
}

model User {
  id                  String        @id @default(cuid())
  email               String        @unique
  // Nullable because a Google-first-time-created account (see the `signIn`
  // callback in src/lib/auth.ts) never sets a password — it can only ever
  // authenticate via Google. The Credentials provider's authorize() guards
  // this with a null check before bcrypt.compare.
  passwordHash        String?
  name                String
  username            String?       @unique
  dateOfBirth         DateTime?     @db.Date
  phoneNumber         String?       @unique
  role                Role
  status              AccountStatus @default(ACTIVE)
  // Null means "no cấp" — a self-registered account not (yet) on the 5-level
  // ladder, restricted to exclusive courses/library/announcements/profile
  // (see requireLeveledStudent in src/lib/access.ts, the single choke point
  // that walls the level ladder, lessons/quizzes, and chat off from these
  // accounts). Admins can also set this directly via the student forms.
  grantedLevel        Level?
  // A STUDENT account created purely to be a limited admin (see
  // requireAnyAdminAccess/requireActiveStudent in src/lib/access.ts) — blocked
  // from /dashboard and excluded from student rosters/pickers, unlike a
  // regular dual-role admin (a real student additionally granted an
  // AdminPermission) which keeps studying as normal.
  adminOnly           Boolean       @default(false)
  // Middle tier between STUDENT-with-permissions and SUPER_ADMIN: a real học
  // viên (adminOnly false, grantedLevel set) that a Super Admin designated to
  // hold every content permission SUPER_ADMIN holds (see hasFullAdminAccess
  // in src/lib/access.ts), short-circuiting the AdminPermission table just
  // like SUPER_ADMIN does. Excludes /admin/settings (feature toggles), which
  // stays SUPER_ADMIN-only regardless of this flag. Eligibility is only
  // checked when this is set (setAdminManagerAction) — every write path that
  // can violate it afterward (demoting back to "học sinh", flipping adminOnly
  // true) clears both this and canManageAdmins in the same update so the flag
  // never survives on an ineligible account.
  isAdminManager      Boolean       @default(false)
  // Separate from isAdminManager itself: an Admin Manager only reaches
  // /admin/admins (creating/editing other admins' permissions) if a Super
  // Admin explicitly also grants this — not implied by isAdminManager alone.
  // Meaningless when isAdminManager is false.
  canManageAdmins     Boolean       @default(false)
  // Purely a /admin/admins list-visibility preference, independent of actual
  // permission state — set by removeFromAdminListAction (a dedicated "xóa
  // khỏi danh sách admin" action distinct from the plain revoke-all button,
  // which intentionally leaves this false and keeps the row visible +
  // restorable). Cleared back to false the moment any permission is granted
  // again via setAccountPermissionsAction, so a re-added admin reappears.
  hiddenFromAdminList Boolean       @default(false)
  // Brute-force lockout, separate from the permanent admin-set `status:
  // LOCKED` above — auto-locks after too many wrong passwords in a row (see
  // src/lib/auth.ts authorize()), reset on the next successful login.
  failedLoginAttempts Int           @default(0)
  lockedUntil         DateTime?
  // Null = not yet verified. Only enforced at login when
  // Settings.emailVerificationEnabled is on (see the authorize() check in
  // src/lib/auth.ts) — every pre-existing row is backfilled to non-null in
  // the same migration that adds this column, so turning the toggle on never
  // retroactively locks out an account that existed before it did. A
  // Google-first-time-created account is stamped verified immediately
  // (Google already proved ownership of the address).
  emailVerified       DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  quizAttempts            QuizAttempt[]
  emailVerificationTokens EmailVerificationToken[] @relation("EmailVerificationTokens")
  passwordResetTokens     PasswordResetToken[]     @relation("PasswordResetTokens")
  levelUpRequests         LevelUpRequest[]         @relation("StudentRequests")
  reviewedRequests        LevelUpRequest[]         @relation("ReviewerActions")
  courseGrants            CourseAccessGrant[]      @relation("CourseGrants")
  courseGrantsGiven       CourseAccessGrant[]      @relation("CourseGrantsGiven")
  courseLessonCompletions CourseLessonCompletion[] @relation("CourseLessonCompletions")
  courseLevelGrantsGiven  CourseLevelGrant[]       @relation("CourseLevelGrantsGiven")
  announcementReads       AnnouncementRead[]
  libraryGrants           LibraryAccessGrant[]     @relation("LibraryGrants")
  libraryGrantsGiven      LibraryAccessGrant[]     @relation("LibraryGrantsGiven")
  libraryLevelGrantsGiven LibraryLevelGrant[]      @relation("LibraryLevelGrantsGiven")
  chatMessagesSent        ChatMessage[]            @relation("ChatMessagesSent")
  chatThreadReads         ChatThreadRead[]         @relation("ChatThreadReads")
  supportThread           ChatThread?              @relation("SupportThreadOfStudent")
  directThreadsAsUserA    ChatThread[]             @relation("DirectThreadAsUserA")
  directThreadsAsUserB    ChatThread[]             @relation("DirectThreadAsUserB")
  adminPermissions        AdminPermission[]        @relation("AdminPermissions")
  adminPermissionsGranted AdminPermission[]        @relation("AdminPermissionsGranted")
  guestChatMessagesSent   GuestChatMessage[]       @relation("GuestChatMessagesSent")
  guestChatThreadReads    GuestChatThreadRead[]    @relation("GuestChatThreadReads")
  orders                  Order[]                  @relation("StudentOrders")
  ordersConfirmed         Order[]                  @relation("OrderConfirmedBy")
  cartItems               CartItem[]

  @@index([role])
}

// Grants a STUDENT account a limited, specific slice of /admin — the
// account keeps studying at /dashboard as normal (see requireAnyAdminAccess
// in src/lib/access.ts, which is how a single-role User model supports this
// "student + limited admin" dual role without a new Role enum value).
// SUPER_ADMIN accounts bypass this table entirely and always have every
// permission implicitly.
enum AdminPermissionKind {
  MANAGE_COURSES
  MANAGE_LESSONS_QUIZZES
  MANAGE_LIBRARY
  MANAGE_STUDENTS
  MANAGE_CHAT
  MANAGE_LEVEL_UP_REQUESTS
  MANAGE_RESULTS
  MANAGE_ANNOUNCEMENTS
  // "Học sinh" — self-registered accounts not yet on the 5-level ladder
  // (User.grantedLevel null). Separate from MANAGE_STUDENTS ("Học viên",
  // leveled accounts) by design — these are two independent flows with
  // their own admin page (/admin/prospective-students) and review queue.
  MANAGE_PROSPECTIVE_STUDENTS
  // Narrower than MANAGE_STUDENTS on purpose: revoking a học viên's level
  // (pushing grantedLevel back to null, i.e. demoting them back to "học
  // sinh") is a separate, explicitly-grantable capability, not implied by
  // plain MANAGE_STUDENTS — see requireAdminPermission("DEMOTE_STUDENTS")
  // call sites in admin/students/actions.ts.
  DEMOTE_STUDENTS
  // MANAGE_STUDENTS/MANAGE_PROSPECTIVE_STUDENTS above only grant viewing the
  // list/detail page and creating new accounts now — editing, locking, and
  // deleting an existing học viên or học sinh are separate, independently
  // grantable capabilities (explicit user decision: e.g. an admin can be
  // trusted to edit+lock but never delete). Rendered as sub-checkboxes
  // nested under their parent in the admin-permission editor UI — see
  // STUDENT_PERMISSION_GROUPS in src/lib/admin-permissions.ts.
  EDIT_STUDENTS
  LOCK_STUDENTS
  DELETE_STUDENTS
  EDIT_PROSPECTIVE_STUDENTS
  LOCK_PROSPECTIVE_STUDENTS
  DELETE_PROSPECTIVE_STUDENTS
  // Xác nhận/hủy đơn hàng mua khóa học độc quyền/tài liệu thư viện (/admin/orders)
  // — độc lập với MANAGE_COURSES/MANAGE_LIBRARY vì đây là nghiệp vụ tiền bạc,
  // không phải quản lý nội dung.
  MANAGE_ORDERS
  // Catalog sản phẩm vật lý (/admin/products) — độc lập với MANAGE_COURSES/
  // MANAGE_LIBRARY vì Product không phải nội dung số (không có access grant/
  // level gating), chỉ hiển thị cho học viên (xem requireLeveledStudent() ở
  // dashboard/products).
  MANAGE_PRODUCTS
}

model AdminPermission {
  id          String              @id @default(cuid())
  userId      String
  permission  AdminPermissionKind
  grantedById String
  grantedAt   DateTime            @default(now())
  // Soft-revoke marker: null means the grant is active. Revoking sets this
  // instead of deleting the row so the grant survives to be restored later
  // (see restoreRevokedPermissionsAction in admin/admins/actions.ts, which
  // reactivates every row sharing the same revokedAt — the batch from one
  // revoke action) and so "Lịch sử cấp quyền" keeps full history.
  revokedAt   DateTime?

  user      User @relation("AdminPermissions", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User @relation("AdminPermissionsGranted", fields: [grantedById], references: [id])

  @@unique([userId, permission])
}

model Lesson {
  id          String   @id @default(cuid())
  level       Level
  title       String
  description String?  @db.Text
  content     String   @db.Text
  youtubeId   String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quiz Quiz?

  @@index([level, order])
}

model Quiz {
  id            String   @id @default(cuid())
  lessonId      String   @unique
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title         String
  // Null means "use the global Settings.passPercentage" — set here to
  // override the pass threshold for this quiz specifically.
  passThreshold Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id     String @id @default(cuid())
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text   String
  order  Int    @default(0)

  options AnswerOption[]

  @@index([quizId, order])
}

model AnswerOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)

  @@index([questionId])
}

model QuizAttempt {
  id            String   @id @default(cuid())
  studentId     String
  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers       Json
  scorePercent  Int
  passed        Boolean
  passThreshold Int
  attemptedAt   DateTime @default(now())

  @@index([studentId])
  @@index([quizId])
}

model LevelUpRequest {
  id           String        @id @default(cuid())
  studentId    String
  student      User          @relation("StudentRequests", fields: [studentId], references: [id], onDelete: Cascade)
  // Null means the student is requesting to join the 5-level system from a
  // "no cấp" account (User.grantedLevel null) rather than leveling up from an
  // existing one — the same review queue at /admin/level-up-requests handles
  // both cases, distinguished by this field.
  fromLevel    Level?
  toLevel      Level
  status       LevelUpStatus @default(PENDING)
  requestedAt  DateTime      @default(now())
  reviewedAt   DateTime?
  reviewerId   String?
  reviewer     User?         @relation("ReviewerActions", fields: [reviewerId], references: [id])
  reviewerNote String?

  @@index([studentId, status])
}

model Settings {
  id                       Int      @id @default(1)
  passPercentage           Int      @default(80)
  chatEnabled              Boolean  @default(true)
  // Master switch for public self-registration at /register — toggled from
  // /admin/settings (see isRegistrationEnabled in src/lib/access.ts). When
  // false, new signups are rejected; existing accounts are unaffected.
  registrationEnabled      Boolean  @default(true)
  // Master switch for the "Mua ngay" buy flow (see isSalesEnabled in
  // src/lib/access.ts) — defaults off since bank info below starts empty;
  // Super Admin turns it on once bankName/bankAccountNumber are filled in.
  // Never hides /admin/orders or a student's own order history, only new
  // purchases.
  salesEnabled             Boolean  @default(false)
  // Master switch for the bilingual (Tiếng Việt/English) UI — toggled from
  // /admin/settings (see isBilingualEnabled in src/lib/access.ts). When
  // false, every area always renders Vietnamese regardless of a visitor's
  // saved language cookie, and the language switcher is hidden.
  bilingualEnabled         Boolean  @default(false)
  // Master switch for requiring email verification before login — toggled
  // from /admin/settings (see isEmailVerificationEnabled in src/lib/access.ts).
  // Defaults off so nothing changes until a Super Admin opts in (needs a
  // working RESEND_API_KEY configured first). When off, authorize() never
  // checks User.emailVerified at all.
  emailVerificationEnabled Boolean  @default(false)
  // Master switch for the "Đăng nhập bằng Google" button and the Google
  // OAuth flow itself (see isGoogleLoginEnabled in src/lib/access.ts and the
  // signIn callback in src/lib/auth.ts). Defaults off so nothing changes
  // until a Super Admin opts in (needs GOOGLE_CLIENT_ID/SECRET configured
  // first). A brand-new account is only auto-created on first Google
  // sign-in if registrationEnabled is ALSO on — reuses that existing switch
  // rather than adding a second "who can register" toggle.
  googleLoginEnabled       Boolean  @default(false)
  bankName                 String?
  bankAccountNumber        String?
  bankAccountHolder        String?
  bankQrImageUrl           String?
  updatedAt                DateTime @updatedAt
}

// One-time link token emailed on registration (and by the "Gửi lại email
// xác thực" resend action) — consumed and deleted the moment /api/verify-email
// accepts it. A user can hold more than one live row at once (each resend
// creates a new one instead of reusing/extending the old one); verifying
// with any of them deletes all of the user's rows, not just the one used.
model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation("EmailVerificationTokens", fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Same shape and lifecycle as EmailVerificationToken, separate table because
// the two flows are conceptually distinct (proving address ownership vs.
// authorizing a credential change) even though the code that issues/consumes
// them is structurally identical.
model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation("PasswordResetTokens", fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Exclusive courses: a second, independent content track (no Level, no
// level-up gating) — a sequence of video lessons only visible to students
// the Super Admin explicitly grants access to via CourseAccessGrant.
model Course {
  id                        String   @id @default(cuid())
  title                     String
  description               String?  @db.Text
  coverImageUrl             String?
  order                     Int      @default(0)
  // Master hide switch for the /guest/* public site: true removes the course
  // from the guest listing and blocks direct access entirely, regardless of
  // any CourseLesson.visibleToGuest flags below. Default false = listed. This
  // is intentionally NOT what gates individual trial lessons — that's driven
  // purely by CourseLesson.visibleToGuest now (see requireGuestCourseAccess /
  // requireGuestCourseLessonAccess in src/lib/access.ts).
  hiddenFromGuest           Boolean  @default(false)
  // Admin-curated, independent of hiddenFromGuest: only checked by the guest
  // homepage's "Khóa học nổi bật" section, which shows exactly the courses
  // opted in here rather than just the first few by `order`.
  featuredOnHome            Boolean  @default(false)
  // Continuous rule for "học sinh" (grantedLevel null) accounts, mirroring
  // CourseLevelGrant's always-fresh-from-DB semantics — since hasLevelAccess
  // never matches a null grantedLevel, CourseLevelGrant alone can never open
  // a course to học sinh, so this is a dedicated on/off switch instead of a
  // grant row. A future self-registered học sinh gains access automatically,
  // no backfill needed. Checked in studentHasCourseAccess (src/lib/access.ts).
  openToProspectiveStudents Boolean  @default(false)
  // VND, 0 = "không bán" (khóa học vẫn hoạt động như cũ, chỉ cấp qua
  // grant/level-rule như trước giờ) — xem OrderItem cho snapshot giá lúc mua.
  price                     Int      @default(0)
  // Optional discounted price, must be < price when set — the actual amount
  // charged at checkout (see getPricing in src/lib/pricing.ts). Null = no
  // discount, full price applies. Irrelevant when isFree is true.
  salePrice                 Int?
  // Master "free for everyone" switch — distinct from price = 0 ("không
  // bán", still admin-grant-only). True grants every student (học viên +
  // học sinh, including future ones) full access outright, no order/
  // checkout involved — checked first in getCourseAccessLevel
  // (src/lib/access.ts). Does not affect guest access, which stays governed
  // by hiddenFromGuest/CourseLesson.visibleToGuest independently.
  isFree                    Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  lessons     CourseLesson[]
  grants      CourseAccessGrant[]
  levelGrants CourseLevelGrant[]
  orderItems  OrderItem[]
  cartItems   CartItem[]
}

model CourseLesson {
  id             String   @id @default(cuid())
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title          String
  content        String   @db.Text
  youtubeId      String?
  order          Int      @default(0)
  // Independent of student access entirely — only gates the /guest/* public
  // view, and only takes effect when the parent Course isn't hiddenFromGuest.
  // This is now the primary "which lessons can guests try" control (set via
  // the "Cấp quyền học thử cho khách" form on the course edit page), no
  // longer a secondary opt-in nested under a course-level visibility flag.
  visibleToGuest Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  completions CourseLessonCompletion[]

  @@index([courseId, order])
}

model CourseLessonCompletion {
  id             String       @id @default(cuid())
  studentId      String
  student        User         @relation("CourseLessonCompletions", fields: [studentId], references: [id], onDelete: Cascade)
  courseLessonId String
  courseLesson   CourseLesson @relation(fields: [courseLessonId], references: [id], onDelete: Cascade)
  completedAt    DateTime     @default(now())

  @@unique([studentId, courseLessonId])
  @@index([studentId])
}

model CourseAccessGrant {
  id          String     @id @default(cuid())
  studentId   String
  student     User       @relation("CourseGrants", fields: [studentId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  grantedAt   DateTime   @default(now())
  grantedById String?
  grantedBy   User?      @relation("CourseGrantsGiven", fields: [grantedById], references: [id])
  // Set only when this grant came from a paid order (grantedById is null in
  // that case) — the actual source of truth for "was this bought", instead
  // of inferring it from grantedById's nullability, which would get
  // ambiguous the moment a second non-admin grant source is ever added.
  // Lets the revoke UI warn with the real order details (amount, date)
  // instead of a generic "Đã mua" label. Never set on an admin-granted row.
  orderItemId String?    @unique
  orderItem   OrderItem? @relation("CourseGrantOrderItem", fields: [orderItemId], references: [id])

  @@unique([studentId, courseId])
  @@index([studentId])
}

// A continuous rule ("this course is open to Level >= minLevel"), separate
// from CourseAccessGrant's per-student rows — checked fresh alongside it in
// studentHasCourseAccess (src/lib/access.ts), so a student who levels up
// later automatically gains access with no backfill needed.
model CourseLevelGrant {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  minLevel    Level
  grantedAt   DateTime @default(now())
  grantedById String?
  grantedBy   User?    @relation("CourseLevelGrantsGiven", fields: [grantedById], references: [id])

  @@unique([courseId, minLevel])
  @@index([courseId])
}

// A separate, simpler catalog of physical products — not digital content,
// so unlike Course/LibraryItem there is no access-grant/level-gating model
// at all: every học viên sees every product, and that's the entire access
// rule (see requireLeveledStudent() in dashboard/products/*). No lessons, no
// access grants — a paid PRODUCT order (see OrderItem) only ever flips the
// Order to PAID, fulfillment (shipping the physical item) happens outside
// the system using Order.shipping* + the student's own phoneNumber, the
// same manual-trust model as payment confirmation itself.
model Product {
  id                 String   @id @default(cuid())
  title              String
  subtitle           String?
  description        String?  @db.Text
  // e.g. "Package" — shown as a small tag on the catalog card.
  badgeLabel         String?
  imageUrl           String?
  order              Int      @default(0)
  // VND, same convention as Course/LibraryItem.
  price              Int      @default(0)
  salePrice          Int?
  // Commission Volume — display-only figure for now; this app has no
  // compensation-plan/downline logic, just shows the number next to price.
  cv                 Int      @default(0)
  // Non-null only for the one product (today: "sanarey-aria") that gets a
  // fully bespoke landing page instead of the generic detail view — see the
  // branch in dashboard/products/[productId]/page.tsx. Every other product
  // renders the plain fallback detail page.
  slug               String?  @unique
  // Only populated (and only ever read) when slug is set — the 3 lifestyle
  // photos used by that bespoke landing page's "ai nên sử dụng" section.
  // Left null for every ordinary product.
  lifestyleImage1Url String?
  lifestyleImage2Url String?
  lifestyleImage3Url String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  orderItems OrderItem[]
  cartItems  CartItem[]
}

// Library of books/documents (PDFs) — access control mirrors Course exactly
// (CourseAccessGrant/CourseLevelGrant), except guests never get the full
// file: visibleToGuest only unlocks previewFilePath, a server-generated
// truncated copy (first guestPreviewPages pages) built from filePath. Both
// paths point at objects in a private Supabase bucket, never a public URL —
// everything is served through our own authenticated route handlers.
model LibraryItem {
  id                        String            @id @default(cuid())
  title                     String
  author                    String?
  description               String?           @db.Text
  type                      LibraryItemType   @default(BOOK)
  // Defaults to PDF so every existing row keeps behaving exactly as before.
  // INTERACTIVE items have no filePath/previewFilePath — see LibraryBookPage
  // and requireGuestLibraryItemAccess/getLibraryItemAccessLevel in
  // src/lib/access.ts for the format-aware branches.
  format                    LibraryItemFormat @default(PDF)
  coverImageUrl             String?
  // Admin-uploaded backdrop rendered behind the flipbook reader (both PDF
  // and INTERACTIVE formats) — purely decorative "reading nook" background,
  // independent of coverImageUrl (which is the small thumbnail used on
  // listing cards).
  backgroundImageUrl        String?
  // Only set (and required, enforced at the action layer, not by the
  // schema) when format is PDF — INTERACTIVE items have no uploaded file.
  filePath                  String?
  // "N trang" for list views either way — for INTERACTIVE items this is
  // just pages.length, kept in sync on every saveLibraryBookPagesAction.
  pageCount                 Int?
  // Fixed design-pixel canvas size for an INTERACTIVE item, chosen once in
  // the editor and not resizable after (every element's x/y/width/height in
  // LibraryBookPage.elements is relative to this). Null for PDF items.
  bookWidth                 Int?
  bookHeight                Int?
  previewFilePath           String?
  guestPreviewPages         Int?
  order                     Int               @default(0)
  visibleToGuest            Boolean           @default(false)
  // Master hide switch, same convention as Announcement.visibleToStudents:
  // false pulls the item from student and guest access alike (overriding
  // visibleToGuest and any grants) without deleting it or touching grants.
  // Defaults true so existing rows keep showing up unchanged.
  visibleToStudents         Boolean           @default(true)
  // Admin-curated, independent of visibleToGuest: only checked by the guest
  // homepage's "Ebook nổi bật" section, same convention as Course.featuredOnHome.
  featuredOnHome            Boolean           @default(false)
  // Continuous rule for "học sinh" (grantedLevel null) accounts, same
  // convention as Course.openToProspectiveStudents — a dedicated on/off
  // switch since LibraryLevelGrant (Level-typed) can never match a null
  // grantedLevel. Checked in studentHasLibraryItemAccess (src/lib/access.ts).
  openToProspectiveStudents Boolean           @default(false)
  // VND, 0 = "không bán", same convention as Course.price.
  price                     Int               @default(0)
  // Optional discounted price, same convention as Course.salePrice.
  salePrice                 Int?
  // Master "free for everyone" switch, same convention as Course.isFree.
  isFree                    Boolean           @default(false)
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  grants      LibraryAccessGrant[]
  levelGrants LibraryLevelGrant[]
  orderItems  OrderItem[]
  cartItems   CartItem[]
  bookPages   LibraryBookPage[]

  @@index([type, order])
}

// One row per page of an INTERACTIVE-format LibraryItem, composed in the
// admin editor (src/app/admin/library/[itemId]/editor). `elements` is a
// JSON array of positioned items (text/image/shape/button/video/audio),
// validated by the shared zod schema in src/lib/library-book-elements.ts —
// not enforced at the DB layer. Saved via saveLibraryBookPagesAction as a
// full delete-and-recreate transaction (see setCourseGuestAccessAction for
// the same pattern), so `order` is simply the array index at save time.
model LibraryBookPage {
  id                 String      @id @default(cuid())
  libraryItemId      String
  libraryItem        LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  order              Int
  backgroundColor    String?
  backgroundImageUrl String?
  elements           Json
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([libraryItemId, order])
}

model LibraryAccessGrant {
  id            String      @id @default(cuid())
  studentId     String
  student       User        @relation("LibraryGrants", fields: [studentId], references: [id], onDelete: Cascade)
  libraryItemId String
  libraryItem   LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  grantedAt     DateTime    @default(now())
  grantedById   String?
  grantedBy     User?       @relation("LibraryGrantsGiven", fields: [grantedById], references: [id])
  // Same convention as CourseAccessGrant.orderItemId — the real source of
  // truth for "was this bought", set only for order-fulfilled rows.
  orderItemId   String?     @unique
  orderItem     OrderItem?  @relation("LibraryGrantOrderItem", fields: [orderItemId], references: [id])

  @@unique([studentId, libraryItemId])
  @@index([studentId])
}

// A continuous rule ("this item is open to Level >= minLevel"), separate
// from LibraryAccessGrant's per-student rows — checked fresh alongside it in
// studentHasLibraryItemAccess (src/lib/access.ts), same pattern as
// CourseLevelGrant.
model LibraryLevelGrant {
  id            String      @id @default(cuid())
  libraryItemId String
  libraryItem   LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  minLevel      Level
  grantedAt     DateTime    @default(now())
  grantedById   String?
  grantedBy     User?       @relation("LibraryLevelGrantsGiven", fields: [grantedById], references: [id])

  @@unique([libraryItemId, minLevel])
  @@index([libraryItemId])
}

// Bán khóa học độc quyền/tài liệu thư viện qua chuyển khoản ngân hàng thủ
// công (SePay dự kiến tích hợp sau — xem fulfillOrder trong
// src/lib/order-fulfillment.ts, hàm duy nhất cần gọi lại khi có webhook tự
// động, không cần đổi schema). "Đã thanh toán" chỉ đơn giản là tạo đúng
// CourseAccessGrant/LibraryAccessGrant row mà admin vẫn cấp tay bấy lâu nay
// (grantedById: null = hệ thống cấp qua đơn hàng) — không có logic quyền
// riêng nào ở đây, src/lib/access.ts không cần biết Order tồn tại.
model Order {
  id            String      @id @default(cuid())
  // Số ngắn, duy nhất, dùng làm nội dung chuyển khoản — hiển thị dạng
  // "DH" + số này (xem formatOrderCode trong src/lib/orders.ts).
  orderNumber   Int         @unique @default(autoincrement())
  studentId     String
  student       User        @relation("StudentOrders", fields: [studentId], references: [id], onDelete: Cascade)
  status        OrderStatus @default(PENDING)
  totalAmount   Int
  createdAt     DateTime    @default(now())
  paidAt        DateTime?
  cancelledAt   DateTime?
  confirmedById String?
  confirmedBy   User?       @relation("OrderConfirmedBy", fields: [confirmedById], references: [id])

  // Only collected (and only ever read) for a PRODUCT order — a physical
  // good needs somewhere to be shipped, unlike Course/LibraryItem which just
  // grant digital access. Null for every COURSE/LIBRARY_ITEM order. Captured
  // once at checkout (createOrderAction) rather than re-derived from the
  // student's profile, since User has no address field and this may differ
  // from where the buyer actually lives.
  shippingName    String?
  shippingPhone   String?
  shippingAddress String? @db.Text

  // Soft-delete only — set by deleteOrderAction (Super Admin only), which
  // just hides the row from /admin/orders immediately. The row itself (and
  // its OrderItems) is only actually removed once ORDER_TRASH_RETENTION_DAYS
  // (src/lib/orders.ts) have passed, opportunistically purged on the next
  // /admin/orders page load — see purgeExpiredDeletedOrders. Deleting (soft
  // or eventual hard) never revokes access already granted: CourseAccessGrant/
  // LibraryAccessGrant.orderItemId is ON DELETE SET NULL, so a hard purge
  // only orphans the grant from any order record, the student keeps it.
  deletedAt DateTime?

  items OrderItem[]

  @@index([studentId])
  @@index([status])
  @@index([deletedAt])
}

// Discriminated by kind, same convention as ChatThread: exactly one of
// courseId/libraryItemId/productId is populated, matching kind. titleSnapshot/
// priceAtPurchase freeze what was actually paid for — the underlying
// Course/LibraryItem/Product's title or price may change later.
model OrderItem {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  kind            OrderItemKind
  courseId        String?
  course          Course?       @relation(fields: [courseId], references: [id])
  libraryItemId   String?
  libraryItem     LibraryItem?  @relation(fields: [libraryItemId], references: [id])
  // PRODUCT order item — see fulfillOrder in src/lib/order-fulfillment.ts,
  // which deliberately creates no access-grant row for this kind (nothing to
  // grant on a physical good).
  productId       String?
  product         Product?      @relation(fields: [productId], references: [id])
  titleSnapshot   String
  priceAtPurchase Int

  // Back-relations to whichever access grant this item's fulfillment
  // created (at most one of the two, matching kind) — see
  // CourseAccessGrant.orderItemId / LibraryAccessGrant.orderItemId.
  courseAccessGrant  CourseAccessGrant?  @relation("CourseGrantOrderItem")
  libraryAccessGrant LibraryAccessGrant? @relation("LibraryGrantOrderItem")

  @@index([orderId])
}

// Pre-checkout cart — separate from Order/OrderItem on purpose: a row here
// is just "the student picked this," freely added/removed with no order
// yet, and never shown to admin. confirmCartOrderAction (src/app/dashboard/
// cart/actions.ts) is the only place that turns a set of these into one real
// (possibly multi-item) Order and clears the rows it consumed — reusing a
// PENDING Order as the cart itself would have let admin see, and possibly
// act on, an order the student is still actively editing.
model CartItem {
  id            String        @id @default(cuid())
  studentId     String
  student       User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  kind          OrderItemKind
  courseId      String?
  course        Course?       @relation(fields: [courseId], references: [id])
  libraryItemId String?
  libraryItem   LibraryItem?  @relation(fields: [libraryItemId], references: [id])
  productId     String?
  product       Product?      @relation(fields: [productId], references: [id])
  createdAt     DateTime      @default(now())

  @@index([studentId])
}

// In-app announcements (bản tin) — three audiences (khách/học sinh/học
// viên) are each independently opt-in per post, no per-student overrides
// since nothing has asked for that yet.
model Announcement {
  id                   String               @id @default(cuid())
  title                String
  content              String               @db.Text
  coverImageUrl        String?
  category             AnnouncementCategory @default(GENERAL)
  // Only meaningful when visibleToLeveled is true — the admin form always
  // submits a concrete Level in that case (picking the lowest level, Cấp 1,
  // is how "every học viên" is expressed; there is no separate "no minimum"
  // state). Stays nullable because pre-migration rows were backfilled with
  // minLevel left as-is (see the migration for how their effective
  // visibility was preserved).
  minLevel             Level?
  visibleToGuest       Boolean              @default(false)
  // Học sinh (grantedLevel: null, not on the 5-level ladder) — independent
  // of visibleToLeveled/minLevel below, which only ever govern học viên.
  visibleToProspective Boolean              @default(false)
  // Học viên (any grantedLevel) — false means no học viên can see this
  // announcement at all, regardless of minLevel. See announcementVisibleTo()
  // in src/lib/announcements.ts, the single place both this and
  // visibleToProspective are evaluated.
  visibleToLeveled     Boolean              @default(false)
  // Master hide switch: false pulls the announcement from every audience at
  // once (students AND guests), overriding visibleToGuest/visibleToProspective/
  // visibleToLeveled — without deleting it. Defaults true so existing rows
  // keep showing up unchanged.
  visibleToStudents    Boolean              @default(true)
  publishedAt          DateTime             @default(now())
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  reads AnnouncementRead[]

  @@index([publishedAt])
  @@index([category])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  studentId      String
  student        User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([studentId, announcementId])
  @@index([studentId])
}

// One row per conversation regardless of kind — a support message, a DM, and
// a group message are structurally identical (sender/body/attachment), so a
// single discriminated model avoids tripling the message/read schema. Exactly
// one of the three identity fields below is populated, matching `kind`:
//   SUPPORT -> supportStudentId only. The admin side isn't a stored member —
//              any active SUPER_ADMIN may access it (see
//              userCanAccessChatThread in src/lib/access.ts).
//   DIRECT  -> directUserAId + directUserBId, always stored with the
//              lexicographically smaller User.id first (see orderedPair in
//              src/lib/chat.ts) so a pair has exactly one canonical row.
//   GROUP   -> groupLevel only. Membership is never stored — it's the
//              student's *current* grantedLevel re-checked live on every
//              access via hasLevelAccess's >= rule (same as content gating
//              elsewhere), so a student reaches their room plus every room
//              below it. Admins reach every group room regardless of level.
// All three kinds' threads are created lazily (upsert on the relevant unique
// key) the first time a message is sent, mirroring AnnouncementRead's
// create-on-first-need idiom — no seeding required.
model ChatThread {
  id   String         @id @default(cuid())
  kind ChatThreadKind

  supportStudentId String? @unique
  supportStudent   User?   @relation("SupportThreadOfStudent", fields: [supportStudentId], references: [id], onDelete: Cascade)

  directUserAId String?
  directUserA   User?   @relation("DirectThreadAsUserA", fields: [directUserAId], references: [id], onDelete: Cascade)
  directUserBId String?
  directUserB   User?   @relation("DirectThreadAsUserB", fields: [directUserBId], references: [id], onDelete: Cascade)

  groupLevel Level? @unique

  // Denormalized for cheap inbox ordering/preview without an aggregate query
  // per row — updated in the same transaction as each new ChatMessage.
  lastMessageAt      DateTime @default(now())
  lastMessagePreview String?
  createdAt          DateTime @default(now())

  messages ChatMessage[]
  reads    ChatThreadRead[]

  @@unique([directUserAId, directUserBId])
  @@index([kind])
}

model ChatMessage {
  id             String     @id @default(cuid())
  threadId       String
  thread         ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User       @relation("ChatMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  // Nullable together with the four attachment fields below — a message may
  // be attachment-only. At least one of body/attachmentPath is required,
  // enforced by Zod at the server-action boundary (see src/lib/chat.ts),
  // not a DB constraint, matching how this schema keeps validation at the
  // Zod layer rather than CHECK constraints throughout.
  body           String?    @db.Text
  // Object path in the private `chat-attachments` Supabase bucket, never a
  // public URL — same convention as LibraryItem.filePath. Served only
  // through /api/chat/attachments/[messageId], gated by
  // userCanAccessChatThread.
  attachmentPath String?
  attachmentName String?
  attachmentMime String?
  attachmentSize Int?
  createdAt      DateTime   @default(now())

  @@index([threadId, createdAt])
}

// A per-user watermark, not a per-message row like AnnouncementRead — a
// thread can have hundreds of messages, so "unread" is computed as
// messages.createdAt > lastReadAt AND senderId != me, rather than one row
// per message per reader.
model ChatThreadRead {
  id         String     @id @default(cuid())
  threadId   String
  thread     ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId     String
  user       User       @relation("ChatThreadReads", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime   @default(now())

  @@unique([threadId, userId])
  @@index([userId])
}

enum GuestChatSender {
  GUEST
  ADMIN
}

// Deliberately separate from ChatThread/ChatMessage rather than adding a
// fourth ChatThreadKind — every field on those models keys off a real
// User.id (senderId, supportStudentId, etc. are all non-nullable FKs), and
// a guest visitor never has a User row (see requireAnyAdminAccess and the
// User model comment for the other half of "who can act as admin" — this
// is the "who is the OTHER party" half, for anonymous visitors instead).
// Identified purely by an opaque cookie value (see getOrCreateGuestSessionId
// in src/lib/guest-chat.ts) — no name/email is ever collected, matching the
// site's "fully anonymous" guest chat design.
model GuestChatThread {
  id             String @id @default(cuid())
  guestSessionId String @unique

  lastMessageAt      DateTime @default(now())
  lastMessagePreview String?
  createdAt          DateTime @default(now())

  messages GuestChatMessage[]
  reads    GuestChatThreadRead[]
}

model GuestChatMessage {
  id       String          @id @default(cuid())
  threadId String
  thread   GuestChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender   GuestChatSender

  // Set only when sender = ADMIN — which admin replied, for the "who
  // answered" context an admin sees; a GUEST-sent message has no User to
  // attribute (that's the whole point of the anonymous cookie identity).
  senderAdminId String?
  senderAdmin   User?   @relation("GuestChatMessagesSent", fields: [senderAdminId], references: [id], onDelete: SetNull)

  // Text-only for this first cut, unlike ChatMessage — no attachment
  // support yet for anonymous guests.
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}

// Per-admin read watermark, same idiom as ChatThreadRead — any admin with
// MANAGE_CHAT may reply, so unread is tracked per admin, not per thread.
model GuestChatThreadRead {
  id         String          @id @default(cuid())
  threadId   String
  thread     GuestChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  adminId    String
  admin      User            @relation("GuestChatThreadReads", fields: [adminId], references: [id], onDelete: Cascade)
  lastReadAt DateTime        @default(now())

  @@unique([threadId, adminId])
  @@index([adminId])
}
