// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  STUDENT
}

enum AccountStatus {
  ACTIVE
  LOCKED
  PENDING
}

enum Level {
  CUSTOMER
  NEW_STARTER
  JUNIOR
  SENIOR
  CORE_LEADER
}

enum LevelUpStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AnnouncementCategory {
  IMPORTANT
  UPDATE
  GENERAL
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  username     String?       @unique
  dateOfBirth  DateTime?
  phoneNumber  String?       @unique
  role         Role
  status       AccountStatus @default(ACTIVE)
  grantedLevel Level         @default(CUSTOMER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  quizAttempts            QuizAttempt[]
  levelUpRequests         LevelUpRequest[]         @relation("StudentRequests")
  reviewedRequests        LevelUpRequest[]         @relation("ReviewerActions")
  courseGrants            CourseAccessGrant[]      @relation("CourseGrants")
  courseGrantsGiven       CourseAccessGrant[]      @relation("CourseGrantsGiven")
  courseLessonCompletions CourseLessonCompletion[] @relation("CourseLessonCompletions")
  courseLevelGrantsGiven  CourseLevelGrant[]       @relation("CourseLevelGrantsGiven")
  announcementReads       AnnouncementRead[]

  @@index([role])
}

model Lesson {
  id          String   @id @default(cuid())
  level       Level
  title       String
  description String?  @db.Text
  content     String   @db.Text
  youtubeId   String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quiz Quiz?

  @@index([level, order])
}

model Quiz {
  id        String   @id @default(cuid())
  lessonId  String   @unique
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id     String @id @default(cuid())
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text   String
  order  Int    @default(0)

  options AnswerOption[]

  @@index([quizId, order])
}

model AnswerOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)

  @@index([questionId])
}

model QuizAttempt {
  id            String   @id @default(cuid())
  studentId     String
  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers       Json
  scorePercent  Int
  passed        Boolean
  passThreshold Int
  attemptedAt   DateTime @default(now())

  @@index([studentId])
  @@index([quizId])
}

model LevelUpRequest {
  id           String        @id @default(cuid())
  studentId    String
  student      User          @relation("StudentRequests", fields: [studentId], references: [id], onDelete: Cascade)
  fromLevel    Level
  toLevel      Level
  status       LevelUpStatus @default(PENDING)
  requestedAt  DateTime      @default(now())
  reviewedAt   DateTime?
  reviewerId   String?
  reviewer     User?         @relation("ReviewerActions", fields: [reviewerId], references: [id])
  reviewerNote String?

  @@index([studentId, status])
}

model Settings {
  id             Int      @id @default(1)
  passPercentage Int      @default(80)
  updatedAt      DateTime @updatedAt
}

// Exclusive courses: a second, independent content track (no Level, no
// level-up gating) — a sequence of video lessons only visible to students
// the Super Admin explicitly grants access to via CourseAccessGrant.
model Course {
  id            String   @id @default(cuid())
  title         String
  description   String?  @db.Text
  coverImageUrl String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lessons     CourseLesson[]
  grants      CourseAccessGrant[]
  levelGrants CourseLevelGrant[]
}

model CourseLesson {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  content   String   @db.Text
  youtubeId String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  completions CourseLessonCompletion[]

  @@index([courseId, order])
}

model CourseLessonCompletion {
  id             String       @id @default(cuid())
  studentId      String
  student        User         @relation("CourseLessonCompletions", fields: [studentId], references: [id], onDelete: Cascade)
  courseLessonId String
  courseLesson   CourseLesson @relation(fields: [courseLessonId], references: [id], onDelete: Cascade)
  completedAt    DateTime     @default(now())

  @@unique([studentId, courseLessonId])
  @@index([studentId])
}

model CourseAccessGrant {
  id          String   @id @default(cuid())
  studentId   String
  student     User     @relation("CourseGrants", fields: [studentId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  grantedAt   DateTime @default(now())
  grantedById String?
  grantedBy   User?    @relation("CourseGrantsGiven", fields: [grantedById], references: [id])

  @@unique([studentId, courseId])
  @@index([studentId])
}

// A continuous rule ("this course is open to Level >= minLevel"), separate
// from CourseAccessGrant's per-student rows — checked fresh alongside it in
// studentHasCourseAccess (src/lib/access.ts), so a student who levels up
// later automatically gains access with no backfill needed.
model CourseLevelGrant {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  minLevel    Level
  grantedAt   DateTime @default(now())
  grantedById String?
  grantedBy   User?    @relation("CourseLevelGrantsGiven", fields: [grantedById], references: [id])

  @@unique([courseId, minLevel])
  @@index([courseId])
}

// In-app announcements (bản tin) — simpler than the Course grant system on
// purpose: a single optional minLevel threshold per post (null = everyone),
// no per-student overrides, since nothing has asked for that yet.
model Announcement {
  id          String               @id @default(cuid())
  title       String
  content     String               @db.Text
  category    AnnouncementCategory @default(GENERAL)
  minLevel    Level?
  publishedAt DateTime             @default(now())
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  reads AnnouncementRead[]

  @@index([publishedAt])
  @@index([category])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  studentId      String
  student        User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([studentId, announcementId])
  @@index([studentId])
}
