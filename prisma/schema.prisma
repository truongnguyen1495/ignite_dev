// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  STUDENT
}

enum AccountStatus {
  ACTIVE
  LOCKED
}

enum Level {
  CUSTOMER
  NEW_STARTER
  JUNIOR
  SENIOR
  CORE_LEADER
}

enum LevelUpStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AnnouncementCategory {
  IMPORTANT
  UPDATE
  GENERAL
}

enum LibraryItemType {
  BOOK
  DOCUMENT
}

enum ChatThreadKind {
  SUPPORT
  DIRECT
  GROUP
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  username     String?       @unique
  dateOfBirth  DateTime?     @db.Date
  phoneNumber  String?       @unique
  role         Role
  status       AccountStatus @default(ACTIVE)
  // Null means "no cấp" — a self-registered account not (yet) on the 5-level
  // ladder, restricted to exclusive courses/library/announcements/profile
  // (see requireLeveledStudent in src/lib/access.ts, the single choke point
  // that walls the level ladder, lessons/quizzes, and chat off from these
  // accounts). Admins can also set this directly via the student forms.
  grantedLevel Level?
  // A STUDENT account created purely to be a limited admin (see
  // requireAnyAdminAccess/requireActiveStudent in src/lib/access.ts) — blocked
  // from /dashboard and excluded from student rosters/pickers, unlike a
  // regular dual-role admin (a real student additionally granted an
  // AdminPermission) which keeps studying as normal.
  adminOnly    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  quizAttempts            QuizAttempt[]
  levelUpRequests         LevelUpRequest[]         @relation("StudentRequests")
  reviewedRequests        LevelUpRequest[]         @relation("ReviewerActions")
  courseGrants            CourseAccessGrant[]      @relation("CourseGrants")
  courseGrantsGiven       CourseAccessGrant[]      @relation("CourseGrantsGiven")
  courseLessonCompletions CourseLessonCompletion[] @relation("CourseLessonCompletions")
  courseLevelGrantsGiven  CourseLevelGrant[]       @relation("CourseLevelGrantsGiven")
  announcementReads       AnnouncementRead[]
  libraryGrants           LibraryAccessGrant[]     @relation("LibraryGrants")
  libraryGrantsGiven      LibraryAccessGrant[]     @relation("LibraryGrantsGiven")
  libraryLevelGrantsGiven LibraryLevelGrant[]      @relation("LibraryLevelGrantsGiven")
  chatMessagesSent        ChatMessage[]            @relation("ChatMessagesSent")
  chatThreadReads         ChatThreadRead[]         @relation("ChatThreadReads")
  supportThread           ChatThread?              @relation("SupportThreadOfStudent")
  directThreadsAsUserA    ChatThread[]             @relation("DirectThreadAsUserA")
  directThreadsAsUserB    ChatThread[]             @relation("DirectThreadAsUserB")
  adminPermissions        AdminPermission[]        @relation("AdminPermissions")
  adminPermissionsGranted AdminPermission[]        @relation("AdminPermissionsGranted")
  guestChatMessagesSent   GuestChatMessage[]       @relation("GuestChatMessagesSent")
  guestChatThreadReads    GuestChatThreadRead[]    @relation("GuestChatThreadReads")

  @@index([role])
}

// Grants a STUDENT account a limited, specific slice of /admin — the
// account keeps studying at /dashboard as normal (see requireAnyAdminAccess
// in src/lib/access.ts, which is how a single-role User model supports this
// "student + limited admin" dual role without a new Role enum value).
// SUPER_ADMIN accounts bypass this table entirely and always have every
// permission implicitly.
enum AdminPermissionKind {
  MANAGE_COURSES
  MANAGE_LESSONS_QUIZZES
  MANAGE_LIBRARY
  MANAGE_STUDENTS
  MANAGE_CHAT
  MANAGE_LEVEL_UP_REQUESTS
  MANAGE_RESULTS
  MANAGE_ANNOUNCEMENTS
  // "Học sinh" — self-registered accounts not yet on the 5-level ladder
  // (User.grantedLevel null). Separate from MANAGE_STUDENTS ("Học viên",
  // leveled accounts) by design — these are two independent flows with
  // their own admin page (/admin/prospective-students) and review queue.
  MANAGE_PROSPECTIVE_STUDENTS
  // Narrower than MANAGE_STUDENTS on purpose: revoking a học viên's level
  // (pushing grantedLevel back to null, i.e. demoting them back to "học
  // sinh") is a separate, explicitly-grantable capability, not implied by
  // plain MANAGE_STUDENTS — see requireAdminPermission("DEMOTE_STUDENTS")
  // call sites in admin/students/actions.ts.
  DEMOTE_STUDENTS
}

model AdminPermission {
  id          String              @id @default(cuid())
  userId      String
  permission  AdminPermissionKind
  grantedById String
  grantedAt   DateTime            @default(now())

  user      User @relation("AdminPermissions", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User @relation("AdminPermissionsGranted", fields: [grantedById], references: [id])

  @@unique([userId, permission])
}

model Lesson {
  id          String   @id @default(cuid())
  level       Level
  title       String
  description String?  @db.Text
  content     String   @db.Text
  youtubeId   String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quiz Quiz?

  @@index([level, order])
}

model Quiz {
  id            String   @id @default(cuid())
  lessonId      String   @unique
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title         String
  // Null means "use the global Settings.passPercentage" — set here to
  // override the pass threshold for this quiz specifically.
  passThreshold Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  questions Question[]
  attempts  QuizAttempt[]
}

model Question {
  id     String @id @default(cuid())
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text   String
  order  Int    @default(0)

  options AnswerOption[]

  @@index([quizId, order])
}

model AnswerOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)

  @@index([questionId])
}

model QuizAttempt {
  id            String   @id @default(cuid())
  studentId     String
  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers       Json
  scorePercent  Int
  passed        Boolean
  passThreshold Int
  attemptedAt   DateTime @default(now())

  @@index([studentId])
  @@index([quizId])
}

model LevelUpRequest {
  id           String        @id @default(cuid())
  studentId    String
  student      User          @relation("StudentRequests", fields: [studentId], references: [id], onDelete: Cascade)
  // Null means the student is requesting to join the 5-level system from a
  // "no cấp" account (User.grantedLevel null) rather than leveling up from an
  // existing one — the same review queue at /admin/level-up-requests handles
  // both cases, distinguished by this field.
  fromLevel    Level?
  toLevel      Level
  status       LevelUpStatus @default(PENDING)
  requestedAt  DateTime      @default(now())
  reviewedAt   DateTime?
  reviewerId   String?
  reviewer     User?         @relation("ReviewerActions", fields: [reviewerId], references: [id])
  reviewerNote String?

  @@index([studentId, status])
}

model Settings {
  id                  Int      @id @default(1)
  passPercentage      Int      @default(80)
  chatEnabled         Boolean  @default(true)
  // Master switch for public self-registration at /register — toggled from
  // /admin/settings (see isRegistrationEnabled in src/lib/access.ts). When
  // false, new signups are rejected; existing accounts are unaffected.
  registrationEnabled Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

// Exclusive courses: a second, independent content track (no Level, no
// level-up gating) — a sequence of video lessons only visible to students
// the Super Admin explicitly grants access to via CourseAccessGrant.
model Course {
  id                        String   @id @default(cuid())
  title                     String
  description               String?  @db.Text
  coverImageUrl             String?
  order                     Int      @default(0)
  visibleToGuest            Boolean  @default(false)
  // Admin-curated, independent of visibleToGuest: only checked by the guest
  // homepage's "Khóa học nổi bật" section, which shows exactly the courses
  // opted in here rather than just the first few by `order`.
  featuredOnHome            Boolean  @default(false)
  // Continuous rule for "học sinh" (grantedLevel null) accounts, mirroring
  // CourseLevelGrant's always-fresh-from-DB semantics — since hasLevelAccess
  // never matches a null grantedLevel, CourseLevelGrant alone can never open
  // a course to học sinh, so this is a dedicated on/off switch instead of a
  // grant row. A future self-registered học sinh gains access automatically,
  // no backfill needed. Checked in studentHasCourseAccess (src/lib/access.ts).
  openToProspectiveStudents Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  lessons     CourseLesson[]
  grants      CourseAccessGrant[]
  levelGrants CourseLevelGrant[]
}

model CourseLesson {
  id             String   @id @default(cuid())
  courseId       String
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title          String
  content        String   @db.Text
  youtubeId      String?
  order          Int      @default(0)
  // Independent of student access entirely — only gates the /guest/* public
  // view, and only takes effect when the parent Course is also
  // visibleToGuest. Lets an admin expose a course to guests while still
  // holding back specific lessons (e.g. payment-gated ones not built yet).
  visibleToGuest Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  completions CourseLessonCompletion[]

  @@index([courseId, order])
}

model CourseLessonCompletion {
  id             String       @id @default(cuid())
  studentId      String
  student        User         @relation("CourseLessonCompletions", fields: [studentId], references: [id], onDelete: Cascade)
  courseLessonId String
  courseLesson   CourseLesson @relation(fields: [courseLessonId], references: [id], onDelete: Cascade)
  completedAt    DateTime     @default(now())

  @@unique([studentId, courseLessonId])
  @@index([studentId])
}

model CourseAccessGrant {
  id          String   @id @default(cuid())
  studentId   String
  student     User     @relation("CourseGrants", fields: [studentId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  grantedAt   DateTime @default(now())
  grantedById String?
  grantedBy   User?    @relation("CourseGrantsGiven", fields: [grantedById], references: [id])

  @@unique([studentId, courseId])
  @@index([studentId])
}

// A continuous rule ("this course is open to Level >= minLevel"), separate
// from CourseAccessGrant's per-student rows — checked fresh alongside it in
// studentHasCourseAccess (src/lib/access.ts), so a student who levels up
// later automatically gains access with no backfill needed.
model CourseLevelGrant {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  minLevel    Level
  grantedAt   DateTime @default(now())
  grantedById String?
  grantedBy   User?    @relation("CourseLevelGrantsGiven", fields: [grantedById], references: [id])

  @@unique([courseId, minLevel])
  @@index([courseId])
}

// Library of books/documents (PDFs) — access control mirrors Course exactly
// (CourseAccessGrant/CourseLevelGrant), except guests never get the full
// file: visibleToGuest only unlocks previewFilePath, a server-generated
// truncated copy (first guestPreviewPages pages) built from filePath. Both
// paths point at objects in a private Supabase bucket, never a public URL —
// everything is served through our own authenticated route handlers.
model LibraryItem {
  id                String          @id @default(cuid())
  title             String
  author            String?
  description       String?         @db.Text
  type              LibraryItemType @default(BOOK)
  coverImageUrl     String?
  filePath          String
  pageCount         Int?
  previewFilePath   String?
  guestPreviewPages Int?
  order             Int             @default(0)
  visibleToGuest    Boolean         @default(false)
  // Master hide switch, same convention as Announcement.visibleToStudents:
  // false pulls the item from student and guest access alike (overriding
  // visibleToGuest and any grants) without deleting it or touching grants.
  // Defaults true so existing rows keep showing up unchanged.
  visibleToStudents Boolean         @default(true)
  // Admin-curated, independent of visibleToGuest: only checked by the guest
  // homepage's "Ebook nổi bật" section, same convention as Course.featuredOnHome.
  featuredOnHome    Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  grants      LibraryAccessGrant[]
  levelGrants LibraryLevelGrant[]

  @@index([type, order])
}

model LibraryAccessGrant {
  id            String      @id @default(cuid())
  studentId     String
  student       User        @relation("LibraryGrants", fields: [studentId], references: [id], onDelete: Cascade)
  libraryItemId String
  libraryItem   LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  grantedAt     DateTime    @default(now())
  grantedById   String?
  grantedBy     User?       @relation("LibraryGrantsGiven", fields: [grantedById], references: [id])

  @@unique([studentId, libraryItemId])
  @@index([studentId])
}

// A continuous rule ("this item is open to Level >= minLevel"), separate
// from LibraryAccessGrant's per-student rows — checked fresh alongside it in
// studentHasLibraryItemAccess (src/lib/access.ts), same pattern as
// CourseLevelGrant.
model LibraryLevelGrant {
  id            String      @id @default(cuid())
  libraryItemId String
  libraryItem   LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  minLevel      Level
  grantedAt     DateTime    @default(now())
  grantedById   String?
  grantedBy     User?       @relation("LibraryLevelGrantsGiven", fields: [grantedById], references: [id])

  @@unique([libraryItemId, minLevel])
  @@index([libraryItemId])
}

// In-app announcements (bản tin) — simpler than the Course grant system on
// purpose: a single optional minLevel threshold per post (null = everyone),
// no per-student overrides, since nothing has asked for that yet.
model Announcement {
  id                String               @id @default(cuid())
  title             String
  content           String               @db.Text
  coverImageUrl     String?
  category          AnnouncementCategory @default(GENERAL)
  minLevel          Level?
  visibleToGuest    Boolean              @default(false)
  // Master hide switch: false pulls the announcement from both the
  // student-facing /dashboard/announcements list and the public /guest/*
  // one, overriding visibleToGuest — without deleting it. Defaults true so
  // existing rows keep showing up unchanged.
  visibleToStudents Boolean              @default(true)
  publishedAt       DateTime             @default(now())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  reads AnnouncementRead[]

  @@index([publishedAt])
  @@index([category])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  studentId      String
  student        User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@unique([studentId, announcementId])
  @@index([studentId])
}

// One row per conversation regardless of kind — a support message, a DM, and
// a group message are structurally identical (sender/body/attachment), so a
// single discriminated model avoids tripling the message/read schema. Exactly
// one of the three identity fields below is populated, matching `kind`:
//   SUPPORT -> supportStudentId only. The admin side isn't a stored member —
//              any active SUPER_ADMIN may access it (see
//              userCanAccessChatThread in src/lib/access.ts).
//   DIRECT  -> directUserAId + directUserBId, always stored with the
//              lexicographically smaller User.id first (see orderedPair in
//              src/lib/chat.ts) so a pair has exactly one canonical row.
//   GROUP   -> groupLevel only. Membership is never stored — it's the
//              student's *current* grantedLevel re-checked live on every
//              access via hasLevelAccess's >= rule (same as content gating
//              elsewhere), so a student reaches their room plus every room
//              below it. Admins reach every group room regardless of level.
// All three kinds' threads are created lazily (upsert on the relevant unique
// key) the first time a message is sent, mirroring AnnouncementRead's
// create-on-first-need idiom — no seeding required.
model ChatThread {
  id   String         @id @default(cuid())
  kind ChatThreadKind

  supportStudentId String? @unique
  supportStudent   User?   @relation("SupportThreadOfStudent", fields: [supportStudentId], references: [id], onDelete: Cascade)

  directUserAId String?
  directUserA   User?   @relation("DirectThreadAsUserA", fields: [directUserAId], references: [id], onDelete: Cascade)
  directUserBId String?
  directUserB   User?   @relation("DirectThreadAsUserB", fields: [directUserBId], references: [id], onDelete: Cascade)

  groupLevel Level? @unique

  // Denormalized for cheap inbox ordering/preview without an aggregate query
  // per row — updated in the same transaction as each new ChatMessage.
  lastMessageAt      DateTime @default(now())
  lastMessagePreview String?
  createdAt          DateTime @default(now())

  messages ChatMessage[]
  reads    ChatThreadRead[]

  @@unique([directUserAId, directUserBId])
  @@index([kind])
}

model ChatMessage {
  id             String     @id @default(cuid())
  threadId       String
  thread         ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User       @relation("ChatMessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  // Nullable together with the four attachment fields below — a message may
  // be attachment-only. At least one of body/attachmentPath is required,
  // enforced by Zod at the server-action boundary (see src/lib/chat.ts),
  // not a DB constraint, matching how this schema keeps validation at the
  // Zod layer rather than CHECK constraints throughout.
  body           String?    @db.Text
  // Object path in the private `chat-attachments` Supabase bucket, never a
  // public URL — same convention as LibraryItem.filePath. Served only
  // through /api/chat/attachments/[messageId], gated by
  // userCanAccessChatThread.
  attachmentPath String?
  attachmentName String?
  attachmentMime String?
  attachmentSize Int?
  createdAt      DateTime   @default(now())

  @@index([threadId, createdAt])
}

// A per-user watermark, not a per-message row like AnnouncementRead — a
// thread can have hundreds of messages, so "unread" is computed as
// messages.createdAt > lastReadAt AND senderId != me, rather than one row
// per message per reader.
model ChatThreadRead {
  id         String     @id @default(cuid())
  threadId   String
  thread     ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId     String
  user       User       @relation("ChatThreadReads", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime   @default(now())

  @@unique([threadId, userId])
  @@index([userId])
}

enum GuestChatSender {
  GUEST
  ADMIN
}

// Deliberately separate from ChatThread/ChatMessage rather than adding a
// fourth ChatThreadKind — every field on those models keys off a real
// User.id (senderId, supportStudentId, etc. are all non-nullable FKs), and
// a guest visitor never has a User row (see requireAnyAdminAccess and the
// User model comment for the other half of "who can act as admin" — this
// is the "who is the OTHER party" half, for anonymous visitors instead).
// Identified purely by an opaque cookie value (see getOrCreateGuestSessionId
// in src/lib/guest-chat.ts) — no name/email is ever collected, matching the
// site's "fully anonymous" guest chat design.
model GuestChatThread {
  id             String @id @default(cuid())
  guestSessionId String @unique

  lastMessageAt      DateTime @default(now())
  lastMessagePreview String?
  createdAt          DateTime @default(now())

  messages GuestChatMessage[]
  reads    GuestChatThreadRead[]
}

model GuestChatMessage {
  id       String          @id @default(cuid())
  threadId String
  thread   GuestChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender   GuestChatSender

  // Set only when sender = ADMIN — which admin replied, for the "who
  // answered" context an admin sees; a GUEST-sent message has no User to
  // attribute (that's the whole point of the anonymous cookie identity).
  senderAdminId String?
  senderAdmin   User?   @relation("GuestChatMessagesSent", fields: [senderAdminId], references: [id], onDelete: SetNull)

  // Text-only for this first cut, unlike ChatMessage — no attachment
  // support yet for anonymous guests.
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}

// Per-admin read watermark, same idiom as ChatThreadRead — any admin with
// MANAGE_CHAT may reply, so unread is tracked per admin, not per thread.
model GuestChatThreadRead {
  id         String          @id @default(cuid())
  threadId   String
  thread     GuestChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  adminId    String
  admin      User            @relation("GuestChatThreadReads", fields: [adminId], references: [id], onDelete: Cascade)
  lastReadAt DateTime        @default(now())

  @@unique([threadId, adminId])
  @@index([adminId])
}
